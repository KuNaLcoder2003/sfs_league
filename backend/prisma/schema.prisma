generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  Upcoming
  Ongoing
  Finished
}

enum TossDecision {
  Bat
  Bowl
}

enum BallType {
  FAIR_BALL
  WIDE
  NO_BALL
  DEAD_BALL
}

enum Group {
  GROUP_A
  GROUP_B
}

